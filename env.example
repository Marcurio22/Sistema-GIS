# ============================================================
# BASE DE DATOS POSTGRESQL
# Configurar con los datos del servidor de producción
# ============================================================
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=gisdb
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_postgres_password


# ============================================================
# FLASK
# ============================================================
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
FLASK_APP=src.webapp:create_app
FLASK_ENV=development          # production | development
FLASK_DEBUG=1                  # 0 en producción
FLASK_RUN_HOST=0.0.0.0
FLASK_RUN_PORT=5000


# ============================================================
# GEOSERVER
# ============================================================
GEOSERVER_WMS_URL=http://<host>:<puerto>/geoserver/wms
GEOSERVER_WFS_URL=http://<host>:<puerto>/geoserver/wfs
GEOSERVER_RECINTOS_TYPENAME=gis_project:recintos_con_propietario
GEOSERVER_USER=admin
GEOSERVER_PASSWORD=your_geoserver_password


# ============================================================
# SEGURIDAD — Flask sessions, CSRF, cookies firmadas
# Generar con: python -c "import secrets; print(secrets.token_hex(32))"
# ============================================================
SECRET_KEY=your_secret_key_here


# ============================================================
# AEMET (API meteorológica)
# Obtener en: https://opendata.aemet.es/centrodedescargas/altaUsuario
# ============================================================
AEMET_API_KEY=your_aemet_api_key


# ============================================================
# CORREO (SMTP)
# Configuración por defecto: Gmail con TLS
# ============================================================
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USE_SSL=False
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_password   # Contraseña de aplicación de Google (16 caracteres)
MAIL_DEFAULT_SENDER=your_email@gmail.com

# Alternativa Mailtrap para desarrollo/testing:
# MAIL_SERVER=sandbox.smtp.mailtrap.io
# MAIL_PORT=2525
# MAIL_USE_TLS=True
# MAIL_USE_SSL=False
# MAIL_USERNAME=your_mailtrap_username
# MAIL_PASSWORD=your_mailtrap_password
# MAIL_DEFAULT_SENDER=noreply@agrosigpac.com


# ============================================================
# INFORIEGO (API de riegos)
# ============================================================
INFORIEGO_API_KEY=your_inforiego_api_key